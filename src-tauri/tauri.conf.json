{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage Monitor",
  "version": "0.1.0",
  "identifier": "com.local.codex-usage-monitor",
  "build": {
    "beforeDevCommand": "npm run desktop:prepare && npm run dev",
    "beforeBuildCommand": "npm run desktop:prepare && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "menubar",
        "title": "Codex Usage",
        "url": "/#menubar",
        "width": 390,
        "height": 760,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "dashboard",
        "title": "Codex Usage Monitor",
        "url": "/",
        "width": 1180,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/codex-usage-node"],
    "resources": {
      "../server": "server"
    }
  }
}
