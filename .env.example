# HTTP server. Keep 127.0.0.1 for local-only use.
CODEX_USAGE_HOST=127.0.0.1
CODEX_USAGE_PORT=4177

# Default Codex home on the current machine. Override this when Codex data lives elsewhere.
CODEX_HOME=~/.codex

# Optional explicit source roots. Separate multiple paths with ":" on macOS/Linux and ";" on Windows.
# CODEX_USAGE_SOURCE_ROOTS=~/.codex/sessions:~/.codex/archived_sessions

# Local SQLite database path for normalized usage events.
CODEX_USAGE_DB=./data/codex-usage.sqlite

# Background rescan interval in milliseconds.
CODEX_USAGE_SCAN_INTERVAL_MS=10000

